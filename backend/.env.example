# Server
PORT=3001

# Database (for future PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/hr_attendance

# Zoho Inventory API (OAuth refresh; direct REST — see docs/integrations-zoho.md)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# Primary org id (alias: ZOHO_INVENTORY_ORGANIZATION_ID)
ZOHO_ORGANIZATION_ID=
# API host without trailing path (default: https://www.zohoapis.com; alias: ZOHO_INVENTORY_API_BASE)
ZOHO_API_BASE_URL=
# Zoho accounts endpoint for token refresh (default: https://accounts.zoho.com)
# ZOHO_ACCOUNTS_BASE=
# Custom field: Family — set to the customfield_id from Zoho for that field
# ZOHO_FAMILY_CUSTOMFIELD_ID=
# Request timeout in ms (default: 20000)
# ZOHO_API_TIMEOUT_MS=
