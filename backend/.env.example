# Server
PORT=5001

# Database (for future PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/hr_attendance

# First-time admin: ensureDefaultAdminUser() inserts admin@company.com with ADMIN_PASSWORD or the default
# in code. If the admin user already exists and the password is unknown, set a new one (dev/staging only):
# SYNC_ADMIN_PASSWORD=1
# ADMIN_PASSWORD=your-secure-8+chars
# (Ignored when NODE_ENV=production. Remove SYNC_ADMIN_PASSWORD after a successful reset.)
# ADMIN_USERNAME=admin@company.com

# Instagram Graph API (Business Discovery — official Meta API; optional)
# Used to load `instagram.picUrl` and follower counts. Requires a Facebook app, Instagram
# professional account, and a User or Page access token with instagram_basic, pages_show_list, etc.
# See: https://developers.facebook.com/docs/instagram-api/reference/ig-user
# META_ACCESS_TOKEN=
# Instagram Business Account id (the IG user id of your connected business/creator account).
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Graph API version, e.g. v22.0 (defaults to v22.0 if unset)
# META_GRAPH_API_VERSION=v22.0

# Zoho Inventory API (OAuth refresh; direct REST — see docs/integrations-zoho.md)
#
# Required Zoho OAuth scopes for the weekly report (issue ALL of these on the
# refresh token at https://api-console.zoho.com → Self Client → Generate Code):
#   ZohoInventory.items.READ        → items + custom fields (catalog, family)
#   ZohoInventory.invoices.READ     → "sold"      (GET /inventory/v1/invoices)
#   ZohoInventory.bills.READ        → "purchases" (GET /inventory/v1/bills, filtered by REPORT_VENDOR_ID)
#   ZohoInventory.debitnotes.READ   → "returned_to_wholesale" (GET /inventory/v1/vendorcredits)
#   ZohoInventory.contacts.READ     → optional, only if you later resolve vendor by name lookup
#
# This integration uses **Zoho Inventory v1**, NOT Zoho Books. Books-prefixed scopes
# (ZohoBooks.*) will not work for these endpoints.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# Primary org id (alias: ZOHO_INVENTORY_ORGANIZATION_ID)
ZOHO_ORGANIZATION_ID=
# API host without trailing path (default: https://www.zohoapis.com; alias: ZOHO_INVENTORY_API_BASE)
ZOHO_API_BASE_URL=
# Zoho accounts endpoint for token refresh (default: https://accounts.zoho.com)
# ZOHO_ACCOUNTS_BASE=
# Redirect URI registered in your Zoho API Console app.
# Required by some Self Client configurations for both authorization_code and refresh_token grants.
# Leave blank if your Zoho app does not enforce it; a startup warning will be logged.
# ZOHO_REDIRECT_URI=
# Custom field: Family — set to the customfield_id from Zoho for that field.
# Find via: GET /inventory/v1/items → items[].custom_fields[].customfield_id whose label === "Family".
# When unset, items[].family is "" and a warning is added to zoho.warnings (dev only).
# ZOHO_FAMILY_CUSTOMFIELD_ID=
# Request timeout in ms (default: 20000)
# ZOHO_API_TIMEOUT_MS=

# --- Zoho API guard rails (services/zohoApiClient.js + PostgreSQL tables) ---
# Legacy alias still read: ZOHO_DAILY_API_BUDGET
# ZOHO_DAILY_CALL_LIMIT=9000
# ZOHO_WARNING_LIMIT=7000
# ZOHO_SAFE_STOP_LIMIT=8500
# ZOHO_PER_MINUTE_LIMIT=70
# At cap: wait for rolling window instead of failing (recommended when main report + family-details stack).
# ZOHO_PER_MINUTE_AUTO_WAIT=true
# Max total wait per request before giving up (ms).
# ZOHO_PER_MINUTE_WAIT_MAX_MS=120000
# Items list: omit inactive SKUs at the API (filter_by=Status.Active) — smaller payloads / fewer pages.
# Set to 1 only if you must load inactive items via GET /items (default unset = active only).
# ZOHO_ITEMS_INCLUDE_INACTIVE=
# ZOHO_CACHE_ENABLED=true
# Warm full items catalog once after DB ready (default off).
# ZOHO_AUTO_SYNC_ON_START=0

# Hard stop before Zoho org daily REST limit (~10,000/day UTC). Each call to
# www.zohoapis.com counts. Default 9000. Set to 0 to disable only in emergencies.
# ZOHO_DAILY_API_BUDGET=9000

# TTL (ms) for invoice/bill/vendor-credit detail GET caches (reduces repeat fetches).
# Default 30 minutes.
# ZOHO_DOCUMENT_DETAIL_CACHE_TTL_MS=

# Weekly report — wholesale vendor scoping.
# REPORT_VENDOR_ID is the Zoho `vendor_id` used to filter Bills (purchases) and
# Vendor Credits (returned_to_wholesale). Sold (invoices) is never vendor-filtered.
# REPORT_VENDOR_ID=4265011000000080014
# Per-group override (JSON map of report_group → { vendor_credits_contact_id }):
# WEEKLY_REPORT_VENDORS_JSON={"slow_moving":{"vendor_credits_contact_id":"4265011000000080014"}}
# Local-only escape hatch: when 1, the report runs without REPORT_VENDOR_ID and
# returns purchases/returned_to_wholesale = 0 with a warning.
# Ignored when NODE_ENV=production unless WEEKLY_REPORT_VENDOR_OPTIONAL_ALLOW_PROD=1.
# WEEKLY_REPORT_VENDOR_OPTIONAL=1
# WEEKLY_REPORT_VENDOR_OPTIONAL_ALLOW_PROD=
# Verbose debug fields in the JSON response (always on in non-production):
# WEEKLY_REPORT_VENDOR_DEBUG=1

# --- Weekly report: matrix-aligned family rows + prefetch (two separate variables; each on its own line) ---
#
# Typical rollout (start cold-open guard OFF; monitor before tightening Zoho usage):
#   USE_MATRIX_TOTALS_FOR_FAMILY_ROWS=1
#   BLOCK_COLD_FAMILY_DETAILS_PREFETCH_MISS=0
#
# Align main-table opening/closing with sidebar warehouse matrix (unset or 0 = legacy global stock).
# USE_MATRIX_TOTALS_FOR_FAMILY_ROWS=1
# USE_MATRIX_TOTALS_FOR_FAMILY_ROWS=0
#
# Cold family-details only: when 1, block sidebar if main report was not loaded first (empty matrix + warning).
# Only set to 1 if Zoho daily limits are still pressured after the above. Default keeps cold-open working.
# BLOCK_COLD_FAMILY_DETAILS_PREFETCH_MISS=0
# BLOCK_COLD_FAMILY_DETAILS_PREFETCH_MISS=1
#
# Monitor (logs / JSON): family_stock_total_mismatch (server log JSON),
#   family_matrix_family_builds_used_prefetch_source, weekly_report_prefetch_bundle_stashed,
#   family-details meta.usedPrefetch, stock_total_source, stock_total_fallback_reason.
# calculation_version must match between main report and family-details after deploy (cache bust).
