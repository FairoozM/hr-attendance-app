# Copy to `.env.deploy` (gitignored) and set your public Express API origin.
# Used by `scripts/inject-api-runtime-config.js` when you run `npm run deploy:frontend` or `npm run deploy:all`.
#
# Must be the URL where /api/health returns JSON (nginx/ALB in front of Node is fine).
# Do NOT use the CloudFront SPA hostname unless you configured CloudFront /api/* → this API.
#
HR_PUBLIC_API_URL=https://your-express-or-alb-host.example.com
